# ── Ollama (internal — container: ollama-fctfp5hzjdmdcnnemwi4ubhf) ───────────
OLLAMA_URL=http://ollama-fctfp5hzjdmdcnnemwi4ubhf:11434
OLLAMA_EMBED_MODEL=paraphrase-multilingual:latest
ST_MODEL=paraphrase-multilingual-mpnet-base-v2
# Max tokens the embedding model accepts — chunks sized to this limit.
# paraphrase-multilingual:latest bert.context_length=512 → use 500 (leaves room for [CLS]/[SEP]).
EMBEDDING_MAX_TOKENS=500

# ── Workers / Search (tuned for 0.5 vCPU / 1GB RAM allocation) ─────────────
WORKER_CONCURRENCY=2
PARSE_PROCESS_WORKERS=1
EMBED_BATCH_SIZE=32
INGEST_QUEUE_SIZE=200
SEARCH_TOP_K=10
HYBRID_VECTOR_WEIGHT=0.6
HYBRID_LEXICAL_WEIGHT=0.4
SEARCH_CACHE_TTL=300
SEARCH_CACHE_MAX=1000
