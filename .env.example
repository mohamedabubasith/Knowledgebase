# ─── App ───────────────────────────────────────────────────
APP_ENV=production
APP_SECRET_KEY=change-me-32-chars-minimum
LOG_LEVEL=INFO

# ─── Postgres ──────────────────────────────────────────────
POSTGRES_DSN=postgresql://cortex:cortex@localhost:5432/cortex_kb
POSTGRES_POOL_MIN=5
POSTGRES_POOL_MAX=20

# ─── MinIO ─────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_RAW=raw-documents
MINIO_SECURE=false

# ─── Qdrant ────────────────────────────────────────────────
# Leave blank to use ChromaDB fallback
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=cortex_kb

# ─── ChromaDB fallback (used if Qdrant unreachable) ────────
CHROMA_PERSIST_DIR=./data/chroma

# ─── Unstructured ──────────────────────────────────────────
# Priority: UNSTRUCTURED_API_URL (cloud) → UNSTRUCTURED_LOCAL_URL → local parsers
UNSTRUCTURED_API_URL=
UNSTRUCTURED_API_KEY=
UNSTRUCTURED_LOCAL_URL=http://localhost:8000   # self-hosted container

# ─── Embeddings ────────────────────────────────────────────
# Priority: Ollama → SentenceTransformers
OLLAMA_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text

# SentenceTransformers fallback model (downloaded on first use)
ST_MODEL=all-MiniLM-L6-v2

# ─── Workers ───────────────────────────────────────────────
WORKER_CONCURRENCY=4          # asyncio workers per queue
PARSE_PROCESS_WORKERS=2       # CPU-bound ProcessPoolExecutor size
EMBED_BATCH_SIZE=64
INGEST_QUEUE_SIZE=500

# ─── Search ────────────────────────────────────────────────
SEARCH_TOP_K=10
HYBRID_VECTOR_WEIGHT=0.6
HYBRID_LEXICAL_WEIGHT=0.4
SEARCH_CACHE_TTL=300          # seconds, 0 = disabled
SEARCH_CACHE_MAX=1000

# ─── JWT ───────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
